# Static export — NEXT_PUBLIC_* values are inlined at build time.

# Form endpoint (Formspree / Basin / CRM webhook). If empty, app defaults to
# FormSubmit → catering@shanesribshack.com (first submit may need inbox confirm).
NEXT_PUBLIC_CATERING_FORM_ENDPOINT=

# Live ezCater storefront. If empty, defaults to brand page + UTMs.
NEXT_PUBLIC_EZCATER_URL=https://www.ezcater.com/brand/shanes-rib-shack

# Set automatically when GITHUB_PAGES=true in CI
# NEXT_PUBLIC_BASE_PATH=/shanes-rib-shack-new
